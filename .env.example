# LLM Provider API Keys
MAKO_GEMINI_API_KEY=your-gemini-api-key
MAKO_ANTHROPIC_API_KEY=your-anthropic-api-key

# Default provider: "gemini" or "claude"
MAKO_DEFAULT_PROVIDER=gemini

# Gemini model
MAKO_GEMINI_MODEL=gemini-2.5-flash

# Claude model
MAKO_CLAUDE_MODEL=claude-sonnet-4-20250514
# Claude server-side web tools (only used with Claude provider)
# Web search: real-time search via Anthropic API ($10 per 1000 searches)
MAKO_CLAUDE_WEB_SEARCH=true
# Web fetch: server-side URL fetching (no additional cost beyond tokens)
MAKO_CLAUDE_WEB_FETCH=true

# Workspace path (where SOUL.md, MEMORY.md, etc. live)
MAKO_WORKSPACE_PATH=workspace

# Security settings
MAKO_MAX_ITERATIONS=10
MAKO_MAX_TOOL_CALLS_PER_TURN=20
MAKO_MAX_TOOL_CALLS_PER_MINUTE=30
# Only allowlisted commands can be run via the shell tool.
# curl is intentionally excluded — use web_fetch (which has SSRF protections).
MAKO_SAFE_BINS=date

# Telegram (Phase 3)
# MAKO_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# MAKO_TELEGRAM_ALLOWED_CHAT_IDS_STR=123456789

# Discord
# MAKO_DISCORD_BOT_TOKEN=your-discord-bot-token
# MAKO_DISCORD_ALLOWED_USER_IDS_STR=123456789
