flowchart TB
    subgraph Channels["📡 Channels"]
        CLI["CLI REPL"]
        TG["Telegram Bot"]
        CRON["⏰ Cron Scheduler"]
    end

    subgraph Agent["🔄 Agent Loop · ReAct"]
        CTX["Context Assembler<br/><i>SOUL.md + MEMORY.md + History</i>"]
        LLM["LLM Provider<br/><i>Gemini Flash · Claude Sonnet</i>"]
        DECIDE{Tool calls?}
        RESPOND["💬 Final Response"]
    end

    subgraph Security["🔒 SecurityGuard · Gates Every Tool Call"]
        ALLOW["Command Allowlist"]
        JAIL["Workspace Jail"]
        SSRF["SSRF Protection"]
        RATE["Rate Limiting"]
        AUDIT["Audit Log"]
    end

    subgraph Tools["🔧 Tools"]
        WEB["web_fetch<br/><i>HTTPS · SSRF-protected</i>"]
        SHELL["shell<br/><i>allowlisted commands</i>"]
        FS["read/write file<br/><i>workspace-jailed</i>"]
        MCP["MCP Client<br/><i>any MCP server</i>"]
    end

    subgraph Memory["🧠 Memory"]
        SQL["SQLite History<br/><i>WAL mode</i>"]
        MD["Personality Files<br/><i>SOUL · IDENTITY · MEMORY</i>"]
        COMPACT["Context Compaction<br/><i>auto-summarize at token limit</i>"]
    end

    subgraph Docker["🐳 Docker · Hardened Container"]
        RO["Read-only rootfs"]
        NONROOT["Non-root user"]
        CAPS["All caps dropped"]
        NET["HTTPS-only egress"]
    end

    CLI --> CTX
    TG --> CTX
    CRON --> CTX
    CTX --> LLM
    LLM --> DECIDE
    DECIDE -- No --> RESPOND
    DECIDE -- Yes --> Security
    Security --> Tools
    Tools -- result --> LLM
    Memory -.-> CTX

